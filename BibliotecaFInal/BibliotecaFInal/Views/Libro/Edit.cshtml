@model BibliotecaFInal.Models.Libro

@{
    ViewData["Title"] = "Editar Libro";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card card-app shadow-lg border-0 overflow-hidden">
                <div class="card-header bg-warning text-dark p-4 border-0">
                    <div class="d-flex align-items-center">
                        <div class="bg-white text-warning rounded-circle p-3 me-3 shadow-sm">
                            <i class="fas fa-edit fa-2x"></i>
                        </div>
                        <div>
                            <h3 class="fw-bold mb-0">Modificar Libro</h3>
                            <p class="small opacity-75 mb-0">Actualiza la información técnica o la portada de la obra</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>
                        <input type="hidden" asp-for="IdLibro" />

                        <div class="row">
                            <div class="col-md-7 border-end-md pe-md-4">
                                <h5 class="text-warning fw-bold mb-4 border-bottom pb-2">Datos Generales</h5>

                                <div class="mb-3">
                                    <label asp-for="Titulo" class="form-label small fw-bold text-dark"></label>
                                    <input asp-for="Titulo" class="form-control" placeholder="Título del libro" />
                                    <span asp-validation-for="Titulo" class="text-danger small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Isbn" class="form-label small fw-bold text-dark">ISBN</label>
                                        <input asp-for="Isbn" class="form-control" />
                                        <span asp-validation-for="Isbn" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Precio" class="form-label small fw-bold text-dark"></label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input asp-for="Precio" class="form-control" />
                                        </div>
                                        <span asp-validation-for="Precio" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Sinopsis" class="form-label small fw-bold text-dark"></label>
                                    <textarea asp-for="Sinopsis" class="form-control" rows="4">@Model.Sinopsis</textarea>
                                    <span asp-validation-for="Sinopsis" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="AnioPublicacion" class="form-label small fw-bold text-dark">Año</label>
                                    <input asp-for="AnioPublicacion" type="number" class="form-control" />
                                    <span asp-validation-for="AnioPublicacion" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-5 ps-md-4 mt-4 mt-md-0">
                                <h5 class="text-warning fw-bold mb-4 border-bottom pb-2">Asignaciones y Arte</h5>

                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-dark">Autor</label>
                                    <select asp-for="IdAutor" class="form-select" asp-items="ViewBag.Autore"></select>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-dark">Categoría</label>
                                    <select asp-for="IdCategoria" class="form-select" asp-items="ViewBag.Categoria"></select>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-dark">Editorial</label>
                                    <select asp-for="IdEditorial" class="form-select" asp-items="ViewBag.Editoriale"></select>
                                </div>

                                <div class="card bg-light border-dashed p-3 text-center">
                                    <label class="form-label small fw-bold text-dark d-block">Portada Actual / Nueva</label>

                                    <div id="previewContainer" class="mb-2">
                                        @if (Model.Portada != null)
                                        {
                                            var base64 = Convert.ToBase64String(Model.Portada);
                                            var imgSrc = $"data:image/*;base64,{base64}";
                                            <img id="previewImage" src="@imgSrc" class="rounded shadow-sm img-thumbnail" style="max-height: 200px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <img id="previewImage" src="#" class="rounded shadow-sm img-thumbnail d-none" style="max-height: 200px;" />
                                            <div id="placeholderPreview" class="py-4">
                                                <i class="fas fa-image fa-3x text-muted opacity-25"></i>
                                                <p class="small text-muted mt-2 mb-0">Sin portada registrada</p>
                                            </div>
                                        }
                                    </div>

                                    <div class="mt-3">
                                        <input type="file" name="arc" id="portadaInput" class="form-control form-control-sm" accept="image/*" data-val="false" />
                                        <small class="text-muted extra-small">Sube una nueva imagen para reemplazar la actual</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5 border-top pt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="fas fa-chevron-left me-2"></i>Descartar
                            </a>
                            <button type="submit" class="btn btn-warning px-5 py-2 fw-bold shadow-sm">
                                <i class="fas fa-sync-alt me-2"></i>Actualizar Libro
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {


    <script>
        <script src="~/js/Libro.js" asp-append-version="true"></script>

    </script>
}