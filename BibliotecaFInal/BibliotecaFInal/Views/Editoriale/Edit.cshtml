@model BibliotecaFInal.Models.Editoriale

@{
    ViewData["Title"] = "Editar Editorial";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card card-app shadow-lg border-0">
                <div class="card-header bg-warning text-dark text-center py-4 rounded-top-3 border-0">
                    <div class="mb-2">
                        <i class="fas fa-edit fa-3x"></i>
                    </div>
                    <h3 class="fw-bold mb-0">Modificar Editorial</h3>
                    <p class="small opacity-75 mb-0">Actualiza los datos de contacto del socio editorial</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>
                        <input type="hidden" asp-for="IdEditorial" />

                        <div class="row">
                            <div class="col-12 mb-3">
                                <label asp-for="Nombre" class="form-label fw-bold text-dark small"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted">
                                        <i class="fas fa-building"></i>
                                    </span>
                                    <input asp-for="Nombre" class="form-control border-start-0 ps-0" placeholder="Nombre de la editorial" />
                                </div>
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="Correo" class="form-label fw-bold text-dark small"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted">
                                        <i class="fas fa-envelope"></i>
                                    </span>
                                    <input asp-for="Correo" type="email" class="form-control border-start-0 ps-0" placeholder="correo@ejemplo.com" />
                                </div>
                                <span asp-validation-for="Correo" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="Direccion" class="form-label fw-bold text-dark small"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted">
                                        <i class="fas fa-map-marker-alt"></i>
                                    </span>
                                    <input asp-for="Direccion" class="form-control border-start-0 ps-0" placeholder="Ubicación de la oficina" />
                                </div>
                                <span asp-validation-for="Direccion" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-4">
                                <label asp-for="IdPais" class="form-label fw-bold text-dark small">País</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted">
                                        <i class="fas fa-globe"></i>
                                    </span>
                                    <select asp-for="IdPais" class="form-select border-start-0 ps-0" asp-items="ViewBag.Paises">
                                        <option value="">-- Seleccione un País --</option>
                                    </select>
                                </div>
                                <span asp-validation-for="IdPais" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning text-dark fw-bold py-2 shadow-sm">
                                <i class="fas fa-save me-2"></i>Guardar Cambios
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2 border-0">
                                <i class="fas fa-arrow-left me-2"></i>Descartar y Volver
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}