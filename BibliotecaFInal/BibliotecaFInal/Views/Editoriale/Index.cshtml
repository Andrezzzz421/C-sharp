@model IEnumerable<BibliotecaFInal.Models.Editoriale>

@{
    ViewData["Title"] = "Editoriales";
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-dark fw-bold mb-0">Editoriales</h2>
        <p class="text-muted small">Socios y distribuidores de nuestra colección</p>
    </div>
    <a asp-action="Create" class="btn btn-app shadow-sm">
        <i class="fas fa-plus me-2"></i>Nueva Editorial
    </a>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card h-100 border-0 shadow-sm hover-elevate overflow-hidden">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-primary-subtle text-primary rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                            <i class="fas fa-building fa-lg"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0 text-dark">@item.Nombre</h5>
                            <span class="badge bg-light text-muted border">
                                <i class="fas fa-globe-americas me-1 text-primary"></i>
                                @(item.IdPaisNavigation?.Nombre ?? "País no asignado")
                            </span>
                        </div>
                    </div>

                    <div class="mt-3 border-top pt-3">
                        <div class="d-flex align-items-start mb-2">
                            <i class="fas fa-map-marker-alt text-danger mt-1 me-3"></i>
                            <p class="small text-muted mb-0">@item.Direccion</p>
                        </div>
                        <div class="d-flex align-items-center mb-3">
                            <i class="fas fa-envelope text-info me-3"></i>
                            <p class="small text-muted mb-0">@item.Correo</p>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-2">
                        <a asp-action="Edit" asp-route-id="@item.IdEditorial" class="btn btn-sm btn-outline-warning rounded-pill px-3">
                            <i class="fas fa-edit me-1"></i>Editar
                        </a>
                        <a asp-action="Details" asp-route-id="@item.IdEditorial" class="btn btn-sm btn-outline-info rounded-pill px-3">
                            <i class="fas fa-info-circle me-1"></i>Info
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.IdEditorial" class="btn btn-sm btn-outline-danger rounded-pill px-2">
                            <i class="fas fa-trash"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 bg-white rounded-4 shadow-sm mt-4">
        <div class="mb-3">
            <i class="fas fa-city fa-4x text-muted opacity-25"></i>
        </div>
        <h5 class="text-muted">No hay editoriales en el sistema</h5>
        <p class="small text-muted">Las editoriales son necesarias para registrar nuevos libros.</p>
        <a asp-action="Create" class="btn btn-app px-4 mt-2">Registrar Editorial</a>
    </div>
}