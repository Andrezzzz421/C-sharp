@model IEnumerable<BibliotecaFInal.Models.Categoria>

@{
    ViewData["Title"] = "Categorías Literarias";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-dark fw-bold mb-0">Categorías</h2>
        <p class="text-muted small">Organiza los libros por género o temática</p>
    </div>
    <a asp-action="Create" class="btn btn-app shadow-sm">
        <i class="fas fa-plus me-2"></i>Nueva Categoría
    </a>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 border-0 shadow-sm hover-elevate text-center p-3 card-categoria">
                <div class="card-body d-flex flex-column align-items-center">
                    <div class="mb-3">
                        @if (item.Logo != null)
                        {
                            var base64 = Convert.ToBase64String(item.Logo);
                            var imgSrc = $"data:image/*;base64,{base64}";
                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center shadow-sm" style="width: 90px; height: 90px; overflow: hidden; border: 3px solid #fff;">
                                <img src="@imgSrc" style="width: 100%; height: 100%; object-fit: cover;" />
                            </div>
                        }
                        else
                        {
                            <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center shadow-sm" style="width: 90px; height: 90px;">
                                <i class="fas fa-tags fa-2x"></i>
                            </div>
                        }
                    </div>

                    <h5 class="fw-bold text-dark mb-1">@item.Nombre</h5>
                    <p class="text-muted extra-small mb-3">Género Literario</p>

                    <div class="mt-auto pt-3 border-top w-100 d-flex justify-content-center gap-3">
                        <a asp-action="Edit" asp-route-id="@item.IdCategoria" class="btn-action edit" title="Editar">
                            <i class="fas fa-edit"></i>
                        </a>
                        <a asp-action="Details" asp-route-id="@item.IdCategoria" class="btn-action details" title="Ver Detalles">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.IdCategoria" class="btn-action delete" title="Eliminar">
                            <i class="fas fa-trash"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <div class="bg-light d-inline-block rounded-circle p-4 mb-3">
            <i class="fas fa-folder-open fa-3x text-muted opacity-25"></i>
        </div>
        <h4 class="text-muted">No hay categorías todavía</h4>
        <p class="text-muted small">Comienza creando una para organizar tus libros.</p>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">Crear ahora</a>
    </div>
}