@model BibliotecaFInal.Models.Autore

@{
    ViewData["Title"] = "Editar Autor";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card card-app shadow-lg border-0">
                <div class="card-header bg-primary text-white py-3 rounded-top-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><i class="fas fa-user-edit me-2"></i>Modificar Autor</h4>
                        <span class="badge bg-white text-primary">ID: #@Model.IdAutor</span>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        <input type="hidden" asp-for="IdAutor" />

                        <div class="row">
                            <div class="col-md-4 text-center border-end">
                                <label class="form-label fw-bold d-block mb-3">Foto Actual</label>
                                <div class="position-relative d-inline-block mb-3">
                                    @if (Model.Foto != null)
                                    {
                                        var base64 = Convert.ToBase64String(Model.Foto);
                                        var imgSrc = $"data:image/*;base64,{base64}";
                                        <img src="@imgSrc" class="img-thumbnail shadow-sm rounded-4" style="width:160px; height:160px; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light border rounded-4 d-flex align-items-center justify-content-center mx-auto shadow-sm" style="width:160px; height:160px;">
                                            <i class="fas fa-user fa-4x text-muted opacity-25"></i>
                                        </div>
                                    }
                                </div>

                                <div class="mb-3 px-2">
                                    <label class="form-label small text-muted">Cambiar imagen:</label>
                                    <input type="file" name="arc" class="form-control form-control-sm" accept="image/*" />
                                    <span asp-validation-for="Foto" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-8 ps-md-4">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Nombre" class="form-label fw-bold small"></label>
                                        <input asp-for="Nombre" class="form-control" placeholder="Nombre" />
                                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Apellido" class="form-label fw-bold small"></label>
                                        <input asp-for="Apellido" class="form-control" placeholder="Apellido" />
                                        <span asp-validation-for="Apellido" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Correo" class="form-label fw-bold small"></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                        <input asp-for="Correo" class="form-control" />
                                    </div>
                                    <span asp-validation-for="Correo" class="text-danger small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Genero" class="form-label fw-bold small"></label>
                                        <input asp-for="Genero" class="form-control" />
                                        <span asp-validation-for="Genero" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="IdPaisOrigen" class="form-label fw-bold small">País de Origen</label>
                                        <select asp-for="IdPaisOrigen" class="form-select" asp-items="ViewBag.Paises">
                                            <option value="">-- Seleccione un Pais --</option>
                                        </select>
                                        <span asp-validation-for="IdPaisOrigen" class="text-danger small"></span>
                                    </div>
                                    <div></div>
                                </div>

                                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                                    <a asp-action="Index" class="btn btn-outline-secondary px-4 me-md-2">
                                        <i class="fas fa-times me-2"></i>Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-app px-5">
                                        <i class="fas fa-save me-2"></i>Guardar Cambios
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

