@model IEnumerable<BibliotecaFInal.Models.Autore>

@{
    ViewData["Title"] = "Galería de Autores";
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-dark fw-bold mb-0">Directorio de Autores</h2>
        <p class="text-muted small">Explora los perfiles de los escritores registrados</p>
    </div>
    <a asp-action="Create" class="btn btn-app shadow-sm">
        <i class="fas fa-plus me-2"></i>Nuevo Autor
    </a>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-12 col-sm-6 col-lg-4 col-xl-3 mb-4">
            <div class="card card-app h-100 border-0 shadow-sm hover-elevate">
                <div class="card-body text-center p-4">
                    <div class="mb-3 d-inline-block position-relative">
                        @if (item.Foto != null)
                        {
                            var base64 = Convert.ToBase64String(item.Foto);
                            var imgSrc = $"data:image/*;base64,{base64}";
                            <img src="@imgSrc" class="rounded-circle shadow" style="width: 100px; height: 100px; object-fit: cover; border: 3px solid white;" />
                        }
                        else
                        {
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow mx-auto" style="width: 100px; height: 100px; font-size: 2rem; font-weight: bold;">
                                @(item.Nombre.Substring(0, 1))@(item.Apellido?.Substring(0, 1) ?? "")
                            </div>
                        }

                        <span class="position-absolute bottom-0 end-0 badge rounded-pill @(item.Genero?.ToLower() == "femenino" ? "bg-danger" : "bg-info") border border-2 border-white p-2">
                            <i class="fas @(item.Genero?.ToLower() == "femenino" ? "fa-venus" : "fa-mars") text-white"></i>
                        </span>
                    </div>

                    <h5 class="fw-bold text-dark mb-1">@item.Nombre @item.Apellido</h5>
                    <p class="text-muted small mb-3">
                        <i class="fas fa-globe-americas me-1 text-primary"></i> @(item.IdPaisOrigenNavigation?.Nombre ?? "Origen desconocido")
                    </p>

                    <div class="bg-light rounded-3 p-2 mb-3">
                        <small class="text-muted d-block text-truncate">
                            <i class="fas fa-envelope me-1 small"></i> @item.Correo
                        </small>
                    </div>
                </div>

                <div class="card-footer bg-transparent border-0 pb-4 px-4 d-flex justify-content-center gap-2">
                    <a asp-action="Edit" asp-route-id="@item.IdAutor" class="btn btn-sm btn-outline-warning rounded-pill px-3">
                        <i class="fas fa-edit"></i>
                    </a>
                    <a asp-action="Details" asp-route-id="@item.IdAutor" class="btn btn-sm btn-outline-info rounded-pill px-3">
                        <i class="fas fa-eye"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.IdAutor" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                        <i class="fas fa-trash"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <div class="bg-light d-inline-block rounded-circle p-4 mb-3">
            <i class="fas fa-user-friends fa-3x text-muted opacity-25"></i>
        </div>
        <h4 class="text-muted">No hay autores para mostrar</h4>
        <a asp-action="Create" class="btn btn-link">Comienza agregando uno nuevo</a>
    </div>
}