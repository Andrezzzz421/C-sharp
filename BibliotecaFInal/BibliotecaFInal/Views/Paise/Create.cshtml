@model BibliotecaFInal.Models.Paise

@{
    ViewData["Title"] = "Nuevo País";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card card-app shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-4 rounded-top-3 border-0">
                    <div class="mb-2">
                        <i class="fas fa-map-marker-alt fa-3x"></i>
                    </div>
                    <h3 class="fw-bold mb-0">Registrar País</h3>
                    <p class="small opacity-75 mb-0">Añade una nueva región al catálogo de origen</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                        <div class="mb-4">
                            <label asp-for="Nombre" class="form-label fw-bold text-dark small">Nombre Oficial</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted">
                                    <i class="fas fa-globe"></i>
                                </span>
                                <input asp-for="Nombre" class="form-control border-start-0 ps-0" placeholder="Ej: Colombia, España..." />
                            </div>
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-app py-2 shadow-sm">
                                <i class="fas fa-save me-2"></i>Guardar Ubicación
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2 border-0">
                                <i class="fas fa-arrow-left me-2"></i>Volver al Listado
                            </a>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light border-0 py-3 text-center rounded-bottom-3">
                    <small class="text-muted italic">Asegúrate de no duplicar nombres existentes</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}