@model BibliotecaFInal.Models.Paise

@{
    ViewData["Title"] = "Editar País";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card card-app shadow-lg border-0">
                <div class="card-header bg-warning text-dark text-center py-4 rounded-top-3 border-0">
                    <div class="mb-2">
                        <i class="fas fa-edit fa-3x"></i>
                    </div>
                    <h3 class="fw-bold mb-0">Modificar País</h3>
                    <p class="small opacity-75 mb-0">Actualiza el nombre de la región seleccionada</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                        <input type="hidden" asp-for="IdPais" />

                        <div class="mb-4">
                            <label asp-for="Nombre" class="form-label fw-bold text-dark small">Nombre del País</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted">
                                    <i class="fas fa-globe-americas"></i>
                                </span>
                                <input asp-for="Nombre" class="form-control border-start-0 ps-0" placeholder="Nombre oficial" />
                            </div>
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning text-dark fw-bold py-2 shadow-sm">
                                <i class="fas fa-sync-alt me-2"></i>Guardar Cambios
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2 border-0">
                                <i class="fas fa-arrow-left me-2"></i>Cancelar
                            </a>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light border-0 py-2 text-center rounded-bottom-3">
                    <small class="text-muted small">ID del Registro: <strong>#@Model.IdPais</strong></small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}