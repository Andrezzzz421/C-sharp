@model IEnumerable<BibliotecaFInal.Models.Paise>

@{
    ViewData["Title"] = "Gestión de Países";
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <div class="d-flex">
            <i class="fas fa-globe-americas fa-2x me-3"></i>
            <div>
                <h6 class="fw-bold mb-0">Restricción de Integridad</h6>
                <p class="mb-0 small">@TempData["Error"]</p>
            </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-dark fw-bold mb-0">Configuración Regional</h2>
        <p class="text-muted small">Administra los países de origen para editoriales y autores</p>
    </div>
    <a asp-action="Create" class="btn btn-app shadow-sm">
        <i class="fas fa-plus-circle me-2"></i>Añadir País
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Nombre del País</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary-subtle text-primary rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                            <i class="fas fa-globe-americas"></i>
                                        </div>
                                        <span class="fw-bold text-dark">@item.Nombre</span>
                                    </div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Edit" asp-route-id="@item.IdPais" class="btn btn-white btn-sm border" title="Editar">
                                            <i class="fas fa-pen text-warning"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.IdPais" class="btn btn-white btn-sm border" title="Detalles">
                                            <i class="fas fa-search text-info"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.IdPais" class="btn btn-white btn-sm border" title="Eliminar">
                                            <i class="fas fa-trash text-danger"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5">
                                    <i class="fas fa-map-marked-alt fa-3x text-muted opacity-25 mb-3"></i>
                                    <p class="text-muted">No hay países registrados en la base de datos.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>