@model BibliotecaFInal.Models.Ejemplare

@{
    ViewData["Title"] = "Nuevo Ejemplar";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card card-app shadow-lg border-0">
                <div class="card-header bg-dark text-white text-center py-4 rounded-top-3 border-0">
                    <div class="mb-2">
                        <i class="fas fa-barcode fa-3x"></i>
                    </div>
                    <h3 class="fw-bold mb-0">Registrar Ejemplar</h3>
                    <p class="small opacity-75 mb-0">Asigna una copia física al inventario de la biblioteca</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                        <div class="row">
                            <div class="col-12 mb-3">
                                <label asp-for="IdLibro" class="form-label fw-bold text-dark small">Libro Correspondiente</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted">
                                        <i class="fas fa-book"></i>
                                    </span>
                                    <select asp-for="IdLibro" class="form-select border-start-0 ps-0" asp-items="ViewBag.Libros">
                                        <option value="">-- Seleccione un Libro --</option>
                                    </select>
                                </div>
                                <span asp-validation-for="IdLibro" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="CodigoInventario" class="form-label fw-bold text-dark small">Código de Identificación</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted">
                                        <i class="fas fa-tag"></i>
                                    </span>
                                    <input asp-for="CodigoInventario" class="form-control border-start-0 ps-0" placeholder="Ej: LIB-001-2024" />
                                </div>
                                <span asp-validation-for="CodigoInventario" class="text-danger small"></span>
                                <small class="text-muted extra-small d-block mt-1">Este código debe ser único para cada libro físico.</small>
                            </div>

                            <div class="col-12 mb-4">
                                <label asp-for="Estado" class="form-label fw-bold text-dark small">Estado Inicial</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted">
                                        <i class="fas fa-info-circle"></i>
                                    </span>
                                    <select asp-for="Estado" class="form-select border-start-0 ps-0">
                                        <option value="">-- Seleccione un estado --</option>
                                        <option value="Disponible">Disponible</option>
                                        <option value="Prestado">Prestado</option>
                                        <option value="Reservado">Reservado</option>
                                    </select>
                                </div>
                                <span asp-validation-for="Estado" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-app py-2 shadow-sm">
                                <i class="fas fa-save me-2"></i>Registrar en Sistema
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2 border-0">
                                <i class="fas fa-arrow-left me-2"></i>Volver al Inventario
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}