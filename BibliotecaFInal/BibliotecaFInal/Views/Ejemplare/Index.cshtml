@model IEnumerable<BibliotecaFInal.Models.Ejemplare>

@{
    ViewData["Title"] = "Inventario de Ejemplares";
}



<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-dark fw-bold mb-0">Control de Inventario</h2>
        <p class="text-muted small">Gestión de copias físicas y estados de circulación</p>
    </div>
    <a asp-action="Create" class="btn btn-app shadow-sm">
        <i class="fas fa-barcode me-2"></i>Registrar Ejemplar
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Código de Inventario</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Libro Correspondiente</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted text-center">Estado</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted text-end pe-4">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-dark text-white rounded-2 p-2 me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-tag small"></i>
                                </div>
                                <span class="fw-bold text-dark">@item.CodigoInventario</span>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex flex-column">
                                <span class="text-dark fw-medium">@item.IdLibroNavigation.Titulo</span>
                                <small class="text-muted">ID: #@item.IdLibro</small>
                            </div>
                        </td>
                        <td class="text-center">
                            @{
                                var estadoClass = item.Estado?.ToLower() switch
                                {
                                    "disponible" => "bg-success-subtle text-success",
                                    "prestado" => "bg-warning-subtle text-warning",
                                    "dañado" => "bg-danger-subtle text-danger",
                                    _ => "bg-secondary-subtle text-secondary"
                                };
                            }
                            <span class="badge @estadoClass rounded-pill px-3 py-2">
                                <i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i>
                                @item.Estado
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group shadow-sm rounded-3">
                                <a asp-action="Edit" asp-route-id="@item.IdEjemplar" class="btn btn-white btn-sm border" title="Editar">
                                    <i class="fas fa-pen text-warning"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.IdEjemplar" class="btn btn-white btn-sm border" title="Detalles">
                                    <i class="fas fa-info-circle text-info"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.IdEjemplar" class="btn btn-white btn-sm border" title="Eliminar">
                                    <i class="fas fa-trash text-danger"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-boxes fa-4x text-muted opacity-25 mb-3"></i>
        <h5 class="text-muted">No hay ejemplares registrados</h5>
        <p class="small text-muted">Agrega copias físicas de tus libros para comenzar los préstamos.</p>
    </div>
}